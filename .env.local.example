# Copiá este archivo a .env.local y completá los valores.
# Los tres primeros salen de tu proyecto de Supabase: Settings -> API.

# Project URL (ej. https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# anon / public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service role key -- NUNCA exponer al cliente ni commitear. Solo se usa en el servidor.
SUPABASE_SERVICE_ROLE_KEY=

# URL pública donde corre la app (usada en los links de los emails de invitación).
# En local: http://localhost:3000
# En producción: https://tu-app.vercel.app (o tu dominio propio)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Connection string de Postgres (Project Settings -> Database) -- solo se usa
# para correr scripts/run-migrations.mjs. NUNCA exponer ni commitear.
SUPABASE_DB_URL=
